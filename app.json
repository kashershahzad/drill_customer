{
  "expo": {
    "name": "Drill Customer",
    "slug": "drill-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/appLogo.png",
    "scheme": "drillcustomer",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "sa.com.drill.app",
      "supportsTablet": false,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is used to show your position on the map when you choose a service address and to send that address to the service provider for your booking. For example, when you book a home service, we use your location to display and confirm the address on the map and to share it with the provider so they can reach you.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/appLogo.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "package": "sa.com.drill.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAQiilQ_i4LRPFyMhfLB5ZT3UGMTIxqL0Y"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/appLogo.png"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-localization",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "86d059c4-8392-4ecd-be2b-6235602b4155"
      }
    },
    "owner": "fahadurrehman"
  }
}
